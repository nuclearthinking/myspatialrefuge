{
    "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
    "workspace.library": [
        "./.luals/Umbrella/library",
        "./.luals/pz_stubs.lua"
    ],
    "workspace.checkThirdParty": false,
    "workspace.maxPreload": 10000,
    "workspace.preloadFileSize": 1000,
    "diagnostics.globals": [
        "MSR",
        "require",
        "DebugLog",
        "LogSeverity",
        "isClient",
        "isServer",
        "getDebug",
        "getTimestamp",
        "writeLog"
    ],
    "runtime.version": "Lua 5.1",
    "runtime.builtin": {
        "basic": "enable"
    }
}
